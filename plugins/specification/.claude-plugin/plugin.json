{
  "name": "specification",
  "dependencies": ["coding", "essential"],
  "description": "Design specifications, architecture specs, requirements gathering, and technical documentation with Notion integration for knowledge management",
  "version": "2026-07-14",
  "mcpServers": "./mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "b=\"$(ls -d \"${CLAUDE_PLUGIN_ROOT}\"/../../essential/*/bin 2>/dev/null | sort | tail -n1)\"; [ -n \"$b\" ] || exit 0; exec \"$b/session-start\" --plugin-dir \"${CLAUDE_PLUGIN_ROOT}\" --with-session-id --constitution-paths \"${CLAUDE_PLUGIN_ROOT}\""}]
      }
    ]
  }
}
