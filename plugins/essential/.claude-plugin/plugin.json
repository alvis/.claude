{
  "name": "essential",
  "description": "Documentation creation, code design, product strategy, and Notion integration for knowledge management",
  "version": "2026-07-10",
  "author": {"name": "Alvis HT Tang", "email": "alvis@hilbert.space"},
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/alvis-session-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--with-session-header", "--constitution-paths", "${HOME}/.claude", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/alvis-user-prompt-submit", "args": ["${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ]
  }
}
