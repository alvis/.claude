{
  "name": "essential",
  "description": "Documentation creation, code design, product strategy, and Notion integration for knowledge management",
  "version": "2026-07-14a",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/session-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--with-session-header", "--with-plugin-context", "--constitution-paths", "${HOME}/.claude", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/subagent-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--with-plugin-context", "--constitution-paths", "${HOME}/.claude", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ]
  }
}
