#!/usr/bin/env python3
"""Validate and transport Essential engineering work state.

The implementation deliberately uses only the Python standard library so the
work-state contract is available before a target project installs dependencies.
"""

from __future__ import annotations

import argparse
from collections import Counter, defaultdict, deque
from dataclasses import dataclass
import hashlib
import json
from pathlib import Path, PurePosixPath
import re
import sys
from typing import Any, Iterable


MARKS = {
    "planned": "-",
    "working": "⧗",
    "done": "✓",
    "failed": "X",
    "blocked": "!",
    "cancelled": "⊘",
}
LIFECYCLE_STATUSES = {"initialized", "active", "blocked", "complete", "retiring"}
STATE_SCHEMA = "engineering-work-state/v1"
SNAPSHOT_SCHEMA = "engineering-work-state+json/v1"
HASH_KIND = "engineering-plan-definition-digest-v1"
PARENT_ID = re.compile(r"^[A-Z]{3}$")
CHILD_ID = re.compile(r"^([A-Z]{3})(0[1-9]|[1-9][0-9])$")
WORK_ID = re.compile(r"^[a-z0-9]+(?:[a-z0-9-]*[a-z0-9])?$")
REQUIRED_COLUMNS = (
    "ID",
    "Mark",
    "Status",
    "Task",
    "Depends on",
    "Required",
    "Acceptance",
    "Owner",
    "Evidence / next action",
)
PLACEHOLDERS = {"", "-", "—", "none", "n/a", "not recorded", "pending"}
TASK_DEFINITION = re.compile(r"^(?P<summary>.+?)\s+\[targets:\s*(?P<targets>.*?)\]$")


@dataclass(frozen=True)
class Task:
    id: str
    mark: str
    status: str
    task: str
    depends_on: tuple[str, ...]
    required: bool
    acceptance: str
    owner: str
    evidence: str
    targets: tuple[str, ...] = ()
    line: int = 0

    @property
    def parent_id(self) -> str | None:
        match = CHILD_ID.fullmatch(self.id)
        return match.group(1) if match else None

    @property
    def definition(self) -> dict[str, Any]:
        return {
            "acceptance": self.acceptance,
            "depends_on": sorted(self.depends_on),
            "id": self.id,
            "required": self.required,
            "targets": sorted(self.targets),
            "task": self.task,
        }

    @property
    def snapshot(self) -> dict[str, Any]:
        return {
            **self.definition,
            "evidence_or_next_action": self.evidence,
            "mark": self.mark,
            "owner": self.owner,
            "status": self.status,
        }

    @property
    def task_cell(self) -> str:
        targets = ", ".join(self.targets) if self.targets else "none"
        return f"{self.task} [targets: {targets}]"


@dataclass
class ParsedState:
    path: Path | None
    metadata: dict[str, str]
    status_metadata: dict[str, str]
    tasks: list[Task]
    errors: list[dict[str, Any]]
    migration_required: bool = False


def issue(code: str, message: str, task_id: str | None = None, line: int | None = None) -> dict[str, Any]:
    value: dict[str, Any] = {"code": code, "message": message}
    if task_id:
        value["task_id"] = task_id
    if line:
        value["line"] = line
    return value


def unwrap(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value.startswith("`") and value.endswith("`"):
        return value[1:-1]
    return value


def split_markdown_row(line: str) -> list[str]:
    source = line.strip()
    if source.startswith("|"):
        source = source[1:]
    if source.endswith("|") and not source.endswith(r"\|"):
        source = source[:-1]
    cells: list[str] = []
    current: list[str] = []
    escaped = False
    for char in source:
        if escaped:
            current.append(char)
            escaped = False
        elif char == "\\":
            escaped = True
        elif char == "|":
            cells.append("".join(current).strip())
            current = []
        else:
            current.append(char)
    if escaped:
        current.append("\\")
    cells.append("".join(current).strip())
    return cells


def normalize_key(value: str) -> str:
    return re.sub(r"[^a-z0-9]+", "_", value.strip().lower()).strip("_")


def parse_bullets(lines: list[str]) -> dict[str, str]:
    result: dict[str, str] = {}
    for line in lines:
        match = re.match(r"^-\s+([^:]+):\s*(.*)$", line.strip())
        if match:
            result[normalize_key(match.group(1))] = unwrap(match.group(2))
    return result


def find_section(lines: list[str], title: str) -> tuple[int, int] | None:
    wanted = f"## {title}".lower()
    start = next((index for index, line in enumerate(lines) if line.strip().lower() == wanted), None)
    if start is None:
        return None
    end = next(
        (index for index in range(start + 1, len(lines)) if lines[index].startswith("## ")),
        len(lines),
    )
    return start + 1, end


def parse_dependencies(value: str) -> tuple[str, ...]:
    if value.strip().lower() in PLACEHOLDERS:
        return ()
    return tuple(part.strip() for part in value.split(",") if part.strip())


def parse_targets(value: str) -> tuple[str, ...]:
    if value.strip().lower() in PLACEHOLDERS:
        return ()
    return tuple(part.strip() for part in value.split(",") if part.strip())


def parse_state_text(text: str, path: Path | None = None) -> ParsedState:
    lines = text.splitlines()
    first_section = next((index for index, line in enumerate(lines) if line.startswith("## ")), len(lines))
    metadata = parse_bullets(lines[:first_section])
    errors: list[dict[str, Any]] = []
    schema = metadata.get("schema")
    if schema is None:
        return ParsedState(path, metadata, {}, [], [], migration_required=True)
    if schema != STATE_SCHEMA:
        errors.append(issue("unsupported_schema", f"Schema must be {STATE_SCHEMA!r}."))

    status_bounds = find_section(lines, "Status")
    if status_bounds is None:
        errors.append(issue("missing_status_section", "A resumable state file requires a ## Status section."))
        status_metadata: dict[str, str] = {}
    else:
        status_metadata = parse_bullets(lines[status_bounds[0] : status_bounds[1]])

    task_bounds = find_section(lines, "Tasks")
    tasks: list[Task] = []
    if task_bounds is None:
        errors.append(issue("missing_tasks_section", "A resumable state file requires a ## Tasks section."))
        return ParsedState(path, metadata, status_metadata, tasks, errors)

    table_lines = [
        (index + 1, lines[index])
        for index in range(task_bounds[0], task_bounds[1])
        if lines[index].lstrip().startswith("|")
    ]
    if len(table_lines) < 2:
        errors.append(issue("missing_tasks_table", "## Tasks requires a Markdown table."))
        return ParsedState(path, metadata, status_metadata, tasks, errors)
    header = split_markdown_row(table_lines[0][1])
    if tuple(header) != REQUIRED_COLUMNS:
        errors.append(
            issue(
                "invalid_tasks_header",
                "The task table must begin with: " + " | ".join(REQUIRED_COLUMNS),
                line=table_lines[0][0],
            )
        )
        return ParsedState(path, metadata, status_metadata, tasks, errors)
    separator = split_markdown_row(table_lines[1][1])
    if len(separator) != len(header) or not all(re.fullmatch(r":?-{3,}:?", cell) for cell in separator):
        errors.append(issue("invalid_tasks_separator", "The task table separator is malformed.", line=table_lines[1][0]))
        return ParsedState(path, metadata, status_metadata, tasks, errors)

    for line_number, row_text in table_lines[2:]:
        cells = split_markdown_row(row_text)
        if len(cells) != len(header):
            errors.append(issue("invalid_task_row", f"Expected {len(header)} cells, found {len(cells)}.", line=line_number))
            continue
        required_value = cells[5].strip().lower()
        if required_value not in {"yes", "no"}:
            errors.append(issue("invalid_required", "Required must be yes or no.", cells[0], line_number))
            required = False
        else:
            required = required_value == "yes"
        task_match = TASK_DEFINITION.fullmatch(cells[3])
        if task_match:
            task_summary = task_match.group("summary").strip()
            targets = parse_targets(task_match.group("targets"))
        else:
            errors.append(
                issue(
                    "invalid_task_definition",
                    "Task must use '<summary> [targets: <comma-separated paths>|none]'.",
                    cells[0],
                    line_number,
                )
            )
            task_summary = cells[3]
            targets = ()
        tasks.append(
            Task(
                id=cells[0],
                mark=cells[1],
                status=cells[2],
                task=task_summary,
                depends_on=parse_dependencies(cells[4]),
                required=required,
                acceptance=cells[6],
                owner=cells[7],
                evidence=cells[8],
                targets=targets,
                line=line_number,
            )
        )
    if not tasks:
        errors.append(issue("empty_tasks", "The task table must contain at least one task."))
    return ParsedState(path, metadata, status_metadata, tasks, errors)


def parse_state_file(path: Path) -> ParsedState:
    try:
        raw = path.read_bytes()
        text = raw.decode("utf-8")
    except (OSError, UnicodeDecodeError) as error:
        return ParsedState(path, {}, {}, [], [issue("unreadable_state", str(error))])
    if "\r" in text:
        parsed = parse_state_text(text, path)
        parsed.errors.append(issue("non_lf_newline", "State Markdown must use LF newlines."))
        return parsed
    parsed = parse_state_text(text, path)
    if any(ord(char) < 32 and char != "\n" for char in text) or "\x7f" in text:
        parsed.errors.append(issue("control_character", "State Markdown cannot contain control characters other than LF."))
    return parsed


def canonical_digest(tasks: Iterable[Task]) -> str:
    definitions = [task.definition for task in sorted(tasks, key=lambda item: item.id)]
    encoded = json.dumps(
        {"hash_kind": HASH_KIND, "tasks": definitions},
        ensure_ascii=False,
        separators=(",", ":"),
        sort_keys=True,
    ).encode("utf-8")
    return hashlib.sha256(encoded).hexdigest()


def find_cycle(graph: dict[str, list[str]]) -> list[str]:
    visiting: set[str] = set()
    visited: set[str] = set()
    path: list[str] = []

    def visit(node: str) -> list[str]:
        if node in visiting:
            start = path.index(node)
            return path[start:] + [node]
        if node in visited:
            return []
        visiting.add(node)
        path.append(node)
        for dependency in graph.get(node, []):
            cycle = visit(dependency)
            if cycle:
                return cycle
        path.pop()
        visiting.remove(node)
        visited.add(node)
        return []

    for candidate in sorted(graph):
        cycle = visit(candidate)
        if cycle:
            return cycle
    return []


def graph_topology(parent_graph: dict[str, list[str]]) -> str:
    if not parent_graph:
        return "linear"
    nodes = set(parent_graph)
    edge_count = sum(len(edges) for edges in parent_graph.values())
    indegrees = {node: len(parent_graph[node]) for node in nodes}
    outdegrees = Counter(dependency for values in parent_graph.values() for dependency in values)
    roots = [node for node, degree in indegrees.items() if degree == 0]
    linear = (
        len(roots) == 1
        and edge_count == len(nodes) - 1
        and all(degree <= 1 for degree in indegrees.values())
        and all(outdegrees[node] <= 1 for node in nodes)
    )
    return "linear" if linear else "dag"


def graph_display(graph: dict[str, list[str]]) -> str:
    if not graph:
        return "—"
    outgoing: dict[str, list[str]] = defaultdict(list)
    indegree = {node: 0 for node in graph}
    for node, dependencies in graph.items():
        indegree[node] = len(dependencies)
        for dependency in dependencies:
            outgoing[dependency].append(node)
    layers: list[list[str]] = []
    ready = sorted(node for node, degree in indegree.items() if degree == 0)
    visited = 0
    while ready:
        layer = ready
        layers.append(layer)
        ready = []
        for node in layer:
            visited += 1
            for follower in sorted(outgoing[node]):
                indegree[follower] -= 1
                if indegree[follower] == 0:
                    ready.append(follower)
        ready.sort()
    if visited != len(graph):
        return "cycle"
    complete_layers = True
    for index in range(1, len(layers)):
        expected = set(layers[index - 1])
        if any(set(graph[node]) != expected for node in layers[index]):
            complete_layers = False
            break
    if complete_layers:
        return " → ".join(
            layer[0] if len(layer) == 1 else "{" + ",".join(layer) + "}"
            for layer in layers
        )
    edges = [f"{dependency} → {node}" for node in sorted(graph) for dependency in sorted(graph[node])]
    isolated = [node for node in sorted(graph) if not graph[node] and not outgoing[node]]
    return "; ".join(edges + isolated)


def derived_parent_status(
    parent: Task,
    children: list[Task],
    task_by_id: dict[str, Task],
) -> str:
    considered = [child for child in children if child.required]
    if not considered:
        considered = children
    if considered and all(child.status == "cancelled" for child in considered):
        return "cancelled"
    if considered and all(child.status in {"done", "cancelled"} for child in considered):
        return "done"
    if any(child.status == "failed" for child in considered):
        return "failed"
    if considered and all(child.status == "done" for child in considered):
        return "done"
    if considered and all(child.status == "planned" for child in considered):
        return "planned"
    if any(child.status == "working" for child in considered):
        return "working"
    parent_ready = all(
        task_by_id.get(dependency) and task_by_id[dependency].status == "done"
        for dependency in parent.depends_on
    )
    runnable = parent_ready and any(
        child.status == "planned"
        and all(task_by_id.get(dependency) and task_by_id[dependency].status == "done" for dependency in child.depends_on)
        for child in considered
    )
    return "working" if runnable else "blocked"


def downstream_closure(current: list[Task], previous: list[Task] | None) -> list[str]:
    if previous is None:
        return []
    current_defs = {task.id: task.definition for task in current}
    previous_defs = {task.id: task.definition for task in previous}
    changed = {
        task_id
        for task_id in set(current_defs) | set(previous_defs)
        if current_defs.get(task_id) != previous_defs.get(task_id)
    }
    all_tasks = {task.id: task for task in [*previous, *current]}
    outgoing: dict[str, set[str]] = defaultdict(set)
    children: dict[str, set[str]] = defaultdict(set)
    for task in all_tasks.values():
        for dependency in task.depends_on:
            outgoing[dependency].add(task.id)
        if task.parent_id:
            children[task.parent_id].add(task.id)
            outgoing[task.id].add(task.parent_id)
    # A changed parent definition affects all of its children. A child change
    # affects its roll-up and true dependency descendants, but never an
    # independent or upstream sibling.
    seeds = set(changed)
    for task_id in changed:
        if PARENT_ID.fullmatch(task_id):
            seeds.update(children[task_id])
    closure = set(seeds)
    queue = deque(sorted(seeds))
    while queue:
        node = queue.popleft()
        for follower in sorted(outgoing[node]):
            if follower not in closure:
                closure.add(follower)
                queue.append(follower)
    return sorted(closure)


def validate_parsed(parsed: ParsedState, previous: ParsedState | None = None) -> dict[str, Any]:
    metadata = parsed.metadata
    if parsed.migration_required:
        return {
            "status": "migration_required",
            "schema": None,
            "work_id": metadata.get("work_id"),
            "lifecycle_status": metadata.get("lifecycle_status") or metadata.get("status"),
            "plan_source": metadata.get("plan_source"),
            "plan_digest": metadata.get("plan_digest"),
            "computed_plan_digest": None,
            "hash_kind": metadata.get("hash_kind"),
            "topology": None,
            "parent_graph": {},
            "subtask_graphs": {},
            "status_counts": {},
            "execution_ledger": [],
            "next_owner": metadata.get("next_owner"),
            "next_action": metadata.get("next_action"),
            "active_task_ids": [],
            "failed_task_ids": [],
            "runnable_leaf_task_ids": [],
            "blocked_task_ids": [],
            "invalidated_downstream_closure": [],
            "errors": [issue("migration_required", f"Add Schema: `{STATE_SCHEMA}` through a coordinator-led migration; the validator never rewrites legacy state.")],
        }

    errors = list(parsed.errors)
    tasks = parsed.tasks
    task_by_id: dict[str, Task] = {}
    parents: dict[str, Task] = {}
    children_by_parent: dict[str, list[Task]] = defaultdict(list)
    child_role_parent = metadata.get("parent_task")
    state_role = metadata.get("state_role")
    work_id = metadata.get("work_id", "")
    if not WORK_ID.fullmatch(work_id):
        errors.append(issue("invalid_work_id", "Work ID is required and must be lowercase kebab-case."))

    for task in tasks:
        if task.id in task_by_id:
            errors.append(issue("duplicate_task_id", "Task IDs must be globally unique within a work item.", task.id, task.line))
            continue
        task_by_id[task.id] = task
        if PARENT_ID.fullmatch(task.id):
            parents[task.id] = task
        else:
            match = CHILD_ID.fullmatch(task.id)
            if not match:
                errors.append(issue("invalid_task_id", "Use exactly three uppercase letters for a parent or that ID plus 01..99 for a child.", task.id, task.line))
            else:
                children_by_parent[match.group(1)].append(task)

        expected_mark = MARKS.get(task.status)
        if expected_mark is None:
            errors.append(issue("invalid_task_status", f"Unknown task status {task.status!r}.", task.id, task.line))
        elif task.mark != expected_mark:
            errors.append(issue("mark_status_mismatch", f"Status {task.status!r} requires mark {expected_mark!r}.", task.id, task.line))
        if task.task.strip().lower() in PLACEHOLDERS:
            errors.append(issue("missing_task_definition", "Task text must be non-placeholder.", task.id, task.line))
        if task.acceptance.strip().lower() in PLACEHOLDERS:
            errors.append(issue("missing_acceptance", "Acceptance must be non-placeholder.", task.id, task.line))
        if task.status in {"working", "blocked", "failed"} and task.owner.strip().lower() in PLACEHOLDERS:
            errors.append(issue("missing_owner", f"{task.status} work requires an accountable owner.", task.id, task.line))
        evidence = task.evidence.strip().lower()
        if task.status == "done" and evidence in PLACEHOLDERS:
            errors.append(issue("missing_done_evidence", "Done work requires evidence.", task.id, task.line))
        if task.status == "failed":
            if "attempt:" not in evidence or not ("retry:" in evidence or "disposition:" in evidence):
                errors.append(issue("incomplete_failure_evidence", "Failed work requires attempt: evidence and either retry: or disposition:.", task.id, task.line))
        if task.status == "blocked" and "unblock:" not in evidence:
            errors.append(issue("missing_unblock_action", "Blocked work requires an unblock: action.", task.id, task.line))
        if task.status == "cancelled" and task.required:
            errors.append(issue("required_task_cancelled", "Required scope cannot remain cancelled; revise and reapprove the plan definition so it is optional or removed.", task.id, task.line))
        if len(task.depends_on) != len(set(task.depends_on)):
            errors.append(issue("duplicate_dependency", "Dependencies use set semantics and cannot repeat an ID.", task.id, task.line))
        if len(task.targets) != len(set(task.targets)):
            errors.append(issue("duplicate_target", "Targets use set semantics and cannot repeat a value.", task.id, task.line))

    if state_role not in {"root", "child"}:
        errors.append(issue("invalid_state_role", "State role must be root or child."))
    if state_role == "child":
        if not child_role_parent or not PARENT_ID.fullmatch(child_role_parent):
            errors.append(issue("missing_parent_task", "A child state requires a three-letter Parent task."))
        if parents:
            errors.append(issue("child_state_contains_parent", "A child state table contains only numbered subtasks."))
        if len(children_by_parent) > 1:
            errors.append(issue("multiple_child_prefixes", "A child state may mirror subtasks for exactly one parent."))

    for parent_id, children in children_by_parent.items():
        if parent_id not in parents and not (state_role == "child" and child_role_parent == parent_id):
            for child in children:
                errors.append(issue("orphaned_subtask", f"Subtask prefix {parent_id} has no parent task.", child.id, child.line))

    parent_graph = {task.id: list(task.depends_on) for task in parents.values()}
    subtask_graphs = {
        parent_id: {task.id: list(task.depends_on) for task in sorted(children, key=lambda item: item.id)}
        for parent_id, children in sorted(children_by_parent.items())
    }
    for task in tasks:
        for dependency in task.depends_on:
            if dependency == task.id:
                errors.append(issue("self_dependency", "A task cannot depend on itself.", task.id, task.line))
            if dependency not in task_by_id:
                errors.append(issue("dangling_dependency", f"Dependency {dependency!r} is not present in this task graph.", task.id, task.line))
                continue
            if task.parent_id is None:
                if not PARENT_ID.fullmatch(dependency):
                    errors.append(issue("invalid_parent_dependency", "Parent dependencies must reference parent IDs.", task.id, task.line))
            elif not CHILD_ID.fullmatch(dependency) or dependency[:3] != task.id[:3]:
                errors.append(issue("cross_parent_subtask_dependency", "Subtasks may depend only on siblings with the same parent prefix.", task.id, task.line))

    parent_cycle = find_cycle(parent_graph)
    if parent_cycle:
        errors.append(issue("parent_cycle", "Parent graph contains a cycle: " + " -> ".join(parent_cycle)))
    for parent_id, graph in subtask_graphs.items():
        cycle = find_cycle(graph)
        if cycle:
            errors.append(issue("subtask_cycle", f"{parent_id} subtask graph contains a cycle: " + " -> ".join(cycle)))

    for parent_id, children in children_by_parent.items():
        parent = parents.get(parent_id)
        if parent is None:
            continue
        if parent.required and not any(child.required for child in children):
            errors.append(issue("required_parent_without_required_child", "A required roll-up parent must have at least one required child.", parent.id, parent.line))
        if not parent.required and any(child.required for child in children):
            errors.append(issue("required_child_under_optional_parent", "An optional parent cannot contain a required child; align requiredness explicitly.", parent.id, parent.line))
        derived = derived_parent_status(parent, children, task_by_id)
        if parent.status != derived:
            errors.append(issue("parent_rollup_mismatch", f"Parent status must be derived as {derived!r} from its children.", parent.id, parent.line))

    lifecycle = metadata.get("lifecycle_status") or metadata.get("status")
    if lifecycle not in LIFECYCLE_STATUSES:
        errors.append(issue("invalid_lifecycle_status", "Lifecycle status must be initialized, active, blocked, complete, or retiring."))
    status_lifecycle = parsed.status_metadata.get("lifecycle")
    if not status_lifecycle:
        errors.append(issue("missing_status_lifecycle", "## Status requires a Lifecycle field."))
    elif lifecycle and status_lifecycle != lifecycle:
        errors.append(issue("lifecycle_mismatch", "Header and ## Status lifecycle values must match."))

    computed_digest = canonical_digest(tasks) if tasks else None
    plan_source = metadata.get("plan_source")
    stored_digest = metadata.get("plan_digest")
    hash_kind = metadata.get("hash_kind")
    if state_role == "root":
        if not plan_source:
            errors.append(issue("missing_plan_source", "Root state requires a canonical Plan source pointer."))
        else:
            pure_source = PurePosixPath(plan_source)
            if pure_source.is_absolute() or ".." in pure_source.parts or plan_source.endswith("/"):
                errors.append(issue("invalid_plan_source", "Plan source must be a relative, contained file path."))
            elif parsed.path is not None:
                candidate = (parsed.path.parent / Path(*pure_source.parts)).resolve()
                try:
                    candidate.relative_to(parsed.path.parent.resolve())
                except ValueError:
                    errors.append(issue("invalid_plan_source", "Plan source escapes the work directory."))
                else:
                    if not candidate.is_file():
                        errors.append(issue("missing_plan_source_file", f"Plan source does not exist: {plan_source}"))
        if hash_kind != HASH_KIND:
            errors.append(issue("invalid_hash_kind", f"Hash kind must be {HASH_KIND!r}."))
        if not re.fullmatch(r"[0-9a-f]{64}", stored_digest or ""):
            errors.append(issue("invalid_plan_digest", "Plan digest must be 64 lowercase hexadecimal characters."))
        elif computed_digest != stored_digest:
            errors.append(issue("plan_digest_mismatch", "Stored plan digest does not match immutable task definitions."))

    executable_leaves = [
        task
        for task in tasks
        if task.parent_id is not None or task.id not in children_by_parent
    ]
    required_leaves = [
        task
        for task in executable_leaves
        if task.required and (task.parent_id is None or parents.get(task.parent_id, Task("", "", "", "", (), True, "", "", "")).required)
    ]

    def dependencies_done(task: Task) -> bool:
        if not all(task_by_id.get(dep) and task_by_id[dep].status == "done" for dep in task.depends_on):
            return False
        if task.parent_id:
            parent = parents.get(task.parent_id)
            if parent and not all(task_by_id.get(dep) and task_by_id[dep].status == "done" for dep in parent.depends_on):
                return False
        return True

    runnable = sorted(task.id for task in executable_leaves if task.status == "planned" and dependencies_done(task))

    for task in executable_leaves:
        if task.status in {"working", "done", "failed"} and not dependencies_done(task):
            errors.append(
                issue(
                    "task_started_before_dependencies",
                    f"Executable {task.status} task requires every own and parent predecessor to be done.",
                    task.id,
                    task.line,
                )
            )

    def has_hard_blocker(task: Task, seen: set[str] | None = None) -> bool:
        checked = set() if seen is None else seen
        if task.id in checked:
            return False
        checked.add(task.id)
        dependencies = list(task.depends_on)
        if task.parent_id and (parent := parents.get(task.parent_id)):
            dependencies.extend(parent.depends_on)
        for dependency in dependencies:
            predecessor = task_by_id.get(dependency)
            if predecessor is None:
                continue
            if predecessor.status in {"failed", "blocked", "cancelled"}:
                return True
            if has_hard_blocker(predecessor, checked):
                return True
        return False

    blocked = sorted(
        task.id
        for task in executable_leaves
        if task.status == "blocked" or (task.status == "planned" and has_hard_blocker(task))
    )
    for task in executable_leaves:
        if task.status == "planned" and has_hard_blocker(task):
            errors.append(
                issue(
                    "unreconciled_blocked_task",
                    "A hard failed, blocked, or cancelled predecessor requires explicit ! blocked status and unblock: evidence.",
                    task.id,
                    task.line,
                )
            )
    unfinished_required = [task for task in required_leaves if task.status != "done"]
    runnable_required = set(runnable) & {task.id for task in required_leaves}
    working_required = [task.id for task in required_leaves if task.status == "working"]
    if lifecycle == "complete" and unfinished_required:
        errors.append(issue("incomplete_required_work", "Lifecycle complete requires every required executable leaf to be done."))
    if lifecycle == "blocked" and (not unfinished_required or runnable_required or working_required):
        errors.append(issue("contradictory_blocked_lifecycle", "Lifecycle blocked requires unfinished required work and no runnable or working required leaf."))

    child_graph = next(iter(subtask_graphs.values()), {}) if state_role == "child" else None
    topology_graph = child_graph if child_graph is not None else parent_graph
    topology = graph_topology(topology_graph)
    declared_topology = parsed.status_metadata.get("topology")
    if declared_topology and declared_topology != topology:
        errors.append(issue("topology_mismatch", f"Declared topology must be derived as {topology!r}."))

    previous_tasks = previous.tasks if previous and not previous.migration_required else None
    if previous_tasks is not None:
        old_by_id = {task.id: task for task in previous_tasks}
        new_by_id = {task.id: task for task in tasks}
        for task_id in sorted(set(old_by_id) & set(new_by_id)):
            if old_by_id[task_id].status == "cancelled" and new_by_id[task_id].status != "cancelled":
                errors.append(issue("recycled_cancelled_task_id", "A cancelled task ID is a permanent tombstone and cannot be reactivated.", task_id))
        removed = [old_by_id[task_id] for task_id in sorted(set(old_by_id) - set(new_by_id))]
        added = [new_by_id[task_id] for task_id in sorted(set(new_by_id) - set(old_by_id))]
        for old_task in removed:
            errors.append(issue("removed_task_tombstone", "Task rows are permanent history; retain removed scope as optional and cancelled.", old_task.id))
        for old_task in removed:
            old_without_id = {key: value for key, value in old_task.definition.items() if key != "id"}
            for new_task in added:
                new_without_id = {key: value for key, value in new_task.definition.items() if key != "id"}
                if old_without_id == new_without_id:
                    errors.append(issue("renamed_task_id", f"Task {old_task.id} appears to have been renamed to {new_task.id}; retain the original ID.", new_task.id))
    execution_ledger = [
        {
            "task_id": task.id,
            "mark": task.mark,
            "status": task.status,
            "owner": task.owner,
            "evidence_or_next_action": task.evidence,
        }
        for task in sorted(tasks, key=lambda item: item.id)
    ]
    result = {
        "status": "invalid" if errors else "valid",
        "schema": metadata.get("schema"),
        "work_id": work_id or None,
        "lifecycle_status": lifecycle,
        "plan_source": plan_source,
        "plan_digest": stored_digest,
        "computed_plan_digest": computed_digest,
        "hash_kind": hash_kind,
        "topology": topology,
        "parent_graph": {key: sorted(value) for key, value in sorted(parent_graph.items())},
        "subtask_graphs": {
            parent: {key: sorted(value) for key, value in sorted(graph.items())}
            for parent, graph in sorted(subtask_graphs.items())
        },
        "graph_display": graph_display(topology_graph),
        "subtask_graph_displays": {parent: graph_display(graph) for parent, graph in sorted(subtask_graphs.items())},
        "subtask_topologies": {parent: graph_topology(graph) for parent, graph in sorted(subtask_graphs.items())},
        "status_counts": dict(sorted(Counter(task.status for task in tasks).items())),
        "execution_ledger": execution_ledger,
        "next_owner": metadata.get("next_owner"),
        "next_action": metadata.get("next_action"),
        "active_task_ids": sorted(task.id for task in executable_leaves if task.status == "working"),
        "failed_task_ids": sorted(task.id for task in executable_leaves if task.status == "failed"),
        "runnable_leaf_task_ids": runnable,
        "blocked_task_ids": blocked,
        "invalidated_downstream_closure": downstream_closure(tasks, previous_tasks),
        "errors": errors,
    }
    return result


def canonical_json(value: Any) -> str:
    return json.dumps(value, ensure_ascii=False, separators=(",", ":"), sort_keys=True) + "\n"


def snapshot_from(parsed: ParsedState, report: dict[str, Any]) -> dict[str, Any]:
    return {
        "schema": SNAPSHOT_SCHEMA,
        "work_id": report["work_id"],
        "lifecycle_status": report["lifecycle_status"],
        "updated": parsed.metadata.get("updated"),
        "plan_source": report["plan_source"],
        "plan_digest": report["plan_digest"],
        "hash_kind": report["hash_kind"],
        "topology": report["topology"],
        "parent_graph": report["parent_graph"],
        "subtask_graphs": report["subtask_graphs"],
        "tasks": [task.snapshot for task in sorted(parsed.tasks, key=lambda item: item.id)],
        "execution_ledger": [
            {
                "task_id": task.id,
                "mark": task.mark,
                "status": task.status,
                "owner": task.owner,
                "evidence_or_next_action": task.evidence,
            }
            for task in sorted(parsed.tasks, key=lambda item: item.id)
        ],
        "next_owner": parsed.metadata.get("next_owner"),
        "next_action": parsed.metadata.get("next_action"),
    }


def reject_duplicate_keys(pairs: list[tuple[str, Any]]) -> dict[str, Any]:
    result: dict[str, Any] = {}
    for key, value in pairs:
        if key in result:
            raise ValueError(f"duplicate JSON key: {key}")
        result[key] = value
    return result


def load_json(path: str) -> tuple[Any, str]:
    text = sys.stdin.read() if path == "-" else Path(path).read_bytes().decode("utf-8")
    return json.loads(text, object_pairs_hook=reject_duplicate_keys), text


def contains_control_string(value: Any) -> bool:
    if isinstance(value, str):
        return any(ord(char) < 32 or ord(char) == 127 for char in value)
    if isinstance(value, list):
        return any(contains_control_string(item) for item in value)
    if isinstance(value, dict):
        return any(contains_control_string(key) or contains_control_string(item) for key, item in value.items())
    return False


def task_from_snapshot(value: Any, index: int, errors: list[dict[str, Any]]) -> Task | None:
    if not isinstance(value, dict):
        errors.append(issue("invalid_snapshot_task", f"Task {index} must be an object."))
        return None
    expected = {
        "id", "mark", "status", "task", "depends_on", "required", "acceptance",
        "owner", "evidence_or_next_action", "targets",
    }
    if set(value) != expected:
        errors.append(issue("invalid_snapshot_task_keys", f"Task {index} keys do not match the schema."))
        return None
    if not isinstance(value["depends_on"], list) or not all(isinstance(item, str) for item in value["depends_on"]):
        errors.append(issue("invalid_snapshot_dependencies", f"Task {index} dependencies must be strings."))
        return None
    if not isinstance(value["targets"], list) or not all(isinstance(item, str) for item in value["targets"]):
        errors.append(issue("invalid_snapshot_targets", f"Task {index} targets must be strings."))
        return None
    scalar_keys = {"id", "mark", "status", "task", "acceptance", "owner", "evidence_or_next_action"}
    if not all(isinstance(value[key], str) for key in scalar_keys) or not isinstance(value["required"], bool):
        errors.append(issue("invalid_snapshot_task_types", f"Task {index} contains an invalid value type."))
        return None
    return Task(
        id=value["id"], mark=value["mark"], status=value["status"], task=value["task"],
        depends_on=tuple(value["depends_on"]), required=value["required"], acceptance=value["acceptance"],
        owner=value["owner"], evidence=value["evidence_or_next_action"], targets=tuple(value["targets"]),
        line=index + 1,
    )


def parsed_from_snapshot(snapshot: Any) -> tuple[ParsedState, list[dict[str, Any]]]:
    errors: list[dict[str, Any]] = []
    if not isinstance(snapshot, dict):
        return ParsedState(None, {}, {}, [], [issue("invalid_snapshot", "Snapshot must be a JSON object.")]), errors
    required = {
        "schema", "work_id", "lifecycle_status", "updated", "plan_source", "plan_digest", "hash_kind",
        "topology", "parent_graph", "subtask_graphs", "tasks", "execution_ledger", "next_owner", "next_action",
    }
    if set(snapshot) != required:
        errors.append(issue("invalid_snapshot_keys", "Snapshot keys do not match engineering-work-state+json/v1."))
    if snapshot.get("schema") != SNAPSHOT_SCHEMA:
        errors.append(issue("invalid_snapshot_schema", f"Snapshot schema must be {SNAPSHOT_SCHEMA!r}."))
    string_fields = {"work_id", "lifecycle_status", "plan_source", "plan_digest", "hash_kind", "topology"}
    for field in sorted(string_fields):
        if not isinstance(snapshot.get(field), str):
            errors.append(issue("invalid_snapshot_field_type", f"Snapshot {field} must be a string."))
    for field in ("updated", "next_owner", "next_action"):
        if snapshot.get(field) is not None and not isinstance(snapshot.get(field), str):
            errors.append(issue("invalid_snapshot_field_type", f"Snapshot {field} must be a string or null."))
    if not isinstance(snapshot.get("parent_graph"), dict) or not isinstance(snapshot.get("subtask_graphs"), dict):
        errors.append(issue("invalid_snapshot_graph_type", "Snapshot graphs must be JSON objects."))
    tasks_value = snapshot.get("tasks", [])
    if not isinstance(tasks_value, list):
        errors.append(issue("invalid_snapshot_tasks", "Snapshot tasks must be an array."))
        tasks_value = []
    tasks = [task for index, value in enumerate(tasks_value) if (task := task_from_snapshot(value, index, errors))]
    ledger_value = snapshot.get("execution_ledger", [])
    if not isinstance(ledger_value, list):
        errors.append(issue("invalid_execution_ledger", "Execution ledger must be an array."))
        ledger_value = []
    ledger_by_id: dict[str, dict[str, Any]] = {}
    ledger_keys = {"task_id", "mark", "status", "owner", "evidence_or_next_action"}
    for index, entry in enumerate(ledger_value):
        if not isinstance(entry, dict) or set(entry) != ledger_keys or not all(isinstance(entry[key], str) for key in ledger_keys):
            errors.append(issue("invalid_execution_ledger_entry", f"Execution ledger entry {index} is malformed."))
            continue
        task_id = entry["task_id"]
        if task_id in ledger_by_id:
            errors.append(issue("duplicate_execution_ledger_task", "Execution ledger task IDs must be unique.", task_id))
            continue
        ledger_by_id[task_id] = entry
    tasks_by_id = {task.id: task for task in tasks}
    if set(ledger_by_id) != set(tasks_by_id):
        missing = sorted(set(tasks_by_id) - set(ledger_by_id))
        orphaned = sorted(set(ledger_by_id) - set(tasks_by_id))
        errors.append(issue("execution_ledger_coverage", f"Execution ledger mismatch; missing={missing}, orphaned={orphaned}."))
    for task_id in sorted(set(ledger_by_id) & set(tasks_by_id)):
        entry = ledger_by_id[task_id]
        task = tasks_by_id[task_id]
        expected = {
            "task_id": task.id,
            "mark": task.mark,
            "status": task.status,
            "owner": task.owner,
            "evidence_or_next_action": task.evidence,
        }
        if entry != expected:
            errors.append(issue("execution_ledger_drift", "Execution ledger disagrees with the task row.", task_id))
    metadata = {
        "schema": STATE_SCHEMA,
        "work_id": snapshot.get("work_id") if isinstance(snapshot.get("work_id"), str) else "",
        "lifecycle_status": snapshot.get("lifecycle_status") if isinstance(snapshot.get("lifecycle_status"), str) else "",
        "plan_source": snapshot.get("plan_source") if isinstance(snapshot.get("plan_source"), str) else "",
        "plan_digest": snapshot.get("plan_digest") if isinstance(snapshot.get("plan_digest"), str) else "",
        "hash_kind": snapshot.get("hash_kind") if isinstance(snapshot.get("hash_kind"), str) else "",
        "state_role": "root",
    }
    for field in ("updated", "next_owner", "next_action"):
        if isinstance(snapshot.get(field), str):
            metadata[field] = snapshot[field]
    status = {
        "lifecycle": metadata["lifecycle_status"],
        "topology": snapshot.get("topology") if isinstance(snapshot.get("topology"), str) else "",
    }
    return ParsedState(None, metadata, status, tasks, errors), errors


def escape_cell(value: str) -> str:
    return value.replace("\\", "\\\\").replace("|", r"\|").replace("\n", "<br>")


def render_snapshot(snapshot: dict[str, Any], parsed: ParsedState, report: dict[str, Any]) -> str:
    lines = [
        "# Engineering work",
        "",
        f"- Schema: `{STATE_SCHEMA}`",
        f"- State role: `root`",
        f"- Work ID: `{report['work_id']}`",
        f"- Lifecycle status: `{report['lifecycle_status']}`",
    ]
    if snapshot.get("updated"):
        lines.append(f"- Updated: `{snapshot['updated']}`")
    lines.extend(
        [
            f"- Plan source: `{report['plan_source']}`",
            f"- Plan digest: `{report['plan_digest']}`",
            f"- Hash kind: `{report['hash_kind']}`",
        ]
    )
    if snapshot.get("next_owner"):
        lines.append(f"- Next owner: `{snapshot['next_owner']}`")
    if snapshot.get("next_action"):
        lines.append(f"- Next action: {snapshot['next_action']}")
    lines.extend(
        [
            "",
            "## Status",
            "",
            f"- Lifecycle: `{report['lifecycle_status']}`",
            f"- Topology: `{report['topology']}`",
            f"- Overall graph: `{report['graph_display']}`",
            "",
            "## Tasks",
            "",
            "| " + " | ".join(REQUIRED_COLUMNS) + " |",
            "| " + " | ".join("---" for _ in REQUIRED_COLUMNS) + " |",
        ]
    )
    for task in parsed.tasks:
        values = [
            task.id, task.mark, task.status, task.task_cell,
            ", ".join(task.depends_on) if task.depends_on else "—",
            "yes" if task.required else "no", task.acceptance, task.owner, task.evidence,
        ]
        lines.append("| " + " | ".join(escape_cell(value) for value in values) + " |")
    return "\n".join(lines) + "\n"


def emit_report(report: dict[str, Any]) -> int:
    sys.stdout.write(canonical_json(report))
    if report["status"] == "valid":
        return 0
    return 3 if report["status"] == "migration_required" else 2


def reconcile_child_report(
    parsed: ParsedState,
    report: dict[str, Any],
    explicit_root: Path | None,
) -> None:
    if parsed.metadata.get("state_role", "root") != "child":
        return
    root_path = explicit_root
    if root_path is None and parsed.path is not None and parsed.path.parent.name == "state":
        root_path = parsed.path.parent.parent / "state.md"
    if root_path is None:
        report["errors"].append(issue("root_state_required", "Validating a child state requires its root state.md."))
        report["status"] = "invalid"
        return
    root = parse_state_file(root_path)
    root_report = validate_parsed(root)
    if root_report["status"] != "valid":
        report["errors"].append(issue("invalid_root_state", f"Root state is not valid: {root_path}"))
        report["status"] = "invalid"
        return
    root_tasks = {task.id: task for task in root.tasks}
    if parsed.metadata.get("work_id") != root.metadata.get("work_id"):
        report["errors"].append(issue("child_work_id_drift", "Child and root Work ID values must match."))
    for task in parsed.tasks:
        root_task = root_tasks.get(task.id)
        if root_task is None:
            report["errors"].append(issue("child_task_absent_from_root", "Child state cannot introduce a task absent from the root registry.", task.id))
        elif root_task.snapshot != task.snapshot:
            report["errors"].append(issue("child_task_drift", "Child task definition or execution state disagrees with the root registry.", task.id))
    report["plan_source"] = root_report["plan_source"]
    report["plan_digest"] = root_report["plan_digest"]
    report["computed_plan_digest"] = root_report["computed_plan_digest"]
    report["hash_kind"] = root_report["hash_kind"]
    if report["errors"]:
        report["status"] = "invalid"


def reconcile_root_children(parsed: ParsedState, report: dict[str, Any]) -> None:
    if parsed.metadata.get("state_role") != "root" or parsed.path is None:
        return
    state_directory = parsed.path.parent / "state"
    if not state_directory.exists():
        return
    if state_directory.is_symlink() or not state_directory.is_dir():
        report["errors"].append(issue("invalid_state_directory", "The state mirror path must be a real directory."))
        report["status"] = "invalid"
        return
    root_tasks = {task.id: task for task in parsed.tasks}
    for child_path in sorted(state_directory.iterdir()):
        if child_path.suffix != ".md":
            continue
        relative = child_path.relative_to(parsed.path.parent).as_posix()
        if child_path.is_symlink() or not child_path.is_file():
            report["errors"].append(issue("invalid_child_state_path", f"State mirror must be a regular non-symlink file: {relative}"))
            continue
        child = parse_state_file(child_path)
        # state/ also owns semantic narrative such as plan.md.
        # Reconcile only files that explicitly opt into the v1 mirror contract;
        # direct validation still reports unversioned files as migration_required.
        if child.metadata.get("schema") != STATE_SCHEMA and child.metadata.get("state_role") != "child":
            continue
        child_report = validate_parsed(child)
        if child.metadata.get("state_role") != "child":
            report["errors"].append(issue("invalid_child_state_role", f"Resumable mirror {relative} must declare State role: child."))
        if child.metadata.get("work_id") != parsed.metadata.get("work_id"):
            report["errors"].append(issue("child_work_id_drift", f"Child and root Work ID values differ in {relative}."))
        parent_task = child.metadata.get("parent_task")
        if parent_task not in root_tasks or not PARENT_ID.fullmatch(parent_task or ""):
            report["errors"].append(issue("invalid_child_parent", f"Child Parent task is absent from the root registry: {relative}."))
        for task in child.tasks:
            root_task = root_tasks.get(task.id)
            if root_task is None:
                report["errors"].append(issue("child_task_absent_from_root", f"{relative} introduces a task absent from root.", task.id))
            elif root_task.snapshot != task.snapshot:
                report["errors"].append(issue("child_task_drift", f"{relative} task disagrees with root.", task.id))
        for child_error in child_report["errors"]:
            report["errors"].append(
                issue(
                    "invalid_child_state",
                    f"{relative}: {child_error['code']}: {child_error['message']}",
                    child_error.get("task_id"),
                    child_error.get("line"),
                )
            )
    if report["errors"]:
        report["status"] = "invalid"


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Validate and transport Essential engineering work state.")
    subparsers = parser.add_subparsers(dest="command", required=True)
    validate = subparsers.add_parser("validate", help="validate Markdown work state")
    validate.add_argument("--state", required=True, type=Path)
    validate.add_argument("--previous-state", type=Path)
    validate.add_argument("--root-state", type=Path, help="root registry when validating a child outside state/")
    pack = subparsers.add_parser("pack", help="emit a canonical JSON state snapshot")
    pack.add_argument("--state", required=True, type=Path)
    validate_snapshot = subparsers.add_parser("validate-snapshot", help="validate canonical JSON state")
    validate_snapshot.add_argument("--snapshot", required=True)
    render = subparsers.add_parser("render", help="render canonical Markdown from JSON state")
    render.add_argument("--snapshot", required=True)
    return parser


def main() -> int:
    args = build_parser().parse_args()
    if args.command in {"validate", "pack"}:
        parsed = parse_state_file(args.state)
        previous = parse_state_file(args.previous_state) if args.command == "validate" and args.previous_state else None
        report = validate_parsed(parsed, previous)
        if args.command == "validate":
            if parsed.metadata.get("state_role") == "child":
                reconcile_child_report(parsed, report, args.root_state)
            else:
                reconcile_root_children(parsed, report)
            return emit_report(report)
        if parsed.metadata.get("state_role") != "root":
            report["errors"].append(issue("pack_requires_root_state", "Pack the root state.md complete registry, not a child mirror."))
            report["status"] = "invalid"
        reconcile_root_children(parsed, report)
        if report["status"] != "valid":
            return emit_report(report)
        sys.stdout.write(canonical_json(snapshot_from(parsed, report)))
        return 0

    try:
        snapshot, snapshot_text = load_json(args.snapshot)
    except (OSError, UnicodeDecodeError, json.JSONDecodeError, ValueError) as error:
        return emit_report({
            "status": "invalid", "schema": None, "work_id": None, "lifecycle_status": None,
            "plan_source": None, "plan_digest": None, "computed_plan_digest": None, "hash_kind": None,
            "topology": None, "parent_graph": {}, "subtask_graphs": {}, "status_counts": {},
            "execution_ledger": [], "next_owner": None, "next_action": None,
            "active_task_ids": [], "failed_task_ids": [],
            "runnable_leaf_task_ids": [], "blocked_task_ids": [], "invalidated_downstream_closure": [],
            "errors": [issue("invalid_snapshot_json", str(error))],
        })
    parsed, _ = parsed_from_snapshot(snapshot)
    report = validate_parsed(parsed)
    if isinstance(snapshot, dict):
        if snapshot_text != canonical_json(snapshot):
            report["errors"].append(issue("noncanonical_snapshot_bytes", "Snapshot bytes must exactly equal canonical sorted compact JSON plus one LF."))
        if contains_control_string(snapshot):
            report["errors"].append(issue("snapshot_control_character", "Snapshot strings cannot contain control characters that fail Markdown round-trip."))
        graph_checks = {
            "parent_graph": report.get("parent_graph"),
            "subtask_graphs": report.get("subtask_graphs"),
        }
        for key, derived in graph_checks.items():
            if snapshot.get(key) != derived:
                report["errors"].append(issue("snapshot_graph_drift", f"Snapshot {key} disagrees with task dependencies."))
        if snapshot.get("topology") != report.get("topology"):
            report["errors"].append(issue("snapshot_topology_drift", "Snapshot topology disagrees with its task graph."))
        if not report["errors"] and snapshot != snapshot_from(parsed, report):
            report["errors"].append(issue("snapshot_roundtrip_drift", "Snapshot semantic ordering or fields would change during canonical round-trip."))
        if report["errors"]:
            report["status"] = "invalid"
    if args.command == "validate-snapshot":
        return emit_report(report)
    if report["status"] != "valid":
        return emit_report(report)
    sys.stdout.write(render_snapshot(snapshot, parsed, report))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
