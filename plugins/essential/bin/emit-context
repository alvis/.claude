#!/usr/bin/env bash
set -euo pipefail
# Emit a single instruction file (CLAUDE.md, MAINAGENT.md, SUBAGENT.md) as its
# own hook payload, so each stays under the per-payload preview limit. Resolves
# {{PLUGIN_DIR}} to the file's plugin directory and prints the hook JSON
# envelope. Emits nothing when the file is absent.
# Usage: emit-context <event-name> <file>

ESSENTIAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ESSENTIAL_ROOT/shared/scripts/context.sh"

event="${1:-}"
file="${2:-}"

[ -n "$event" ] && [ -f "$file" ] || exit 0

plugin_dir="$(cd "$(dirname "$file")" && pwd)"
content="$(sed "s|{{PLUGIN_DIR}}|$plugin_dir|g" "$file")"

output_hook_context "$event" "$content"
