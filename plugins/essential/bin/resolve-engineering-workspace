#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: resolve-engineering-workspace [--work-id <id>|--work-id=<id>] [--path <path>|--path=<path>] [--bootstrap]" >&2
}

invalid() {
  jq -n --arg message "$1" '{status:"invalid", error:$message}'
  exit 2
}

valid_work_id() {
  [[ "$1" =~ ^[a-z0-9]+([a-z0-9-]*[a-z0-9])?$ ]]
}

canonical_directory() {
  (cd "$1" && pwd -P)
}

require_safe_directory_component() {
  local target="$1"
  [[ ! -L "$target" ]] || invalid "engineering work directory must not be a symlink: $target"
  if [[ -e "$target" && ! -d "$target" ]]; then
    invalid "engineering work path component is not a directory: $target"
  fi
}

require_safe_entrypoint() {
  local target="$1"
  [[ ! -L "$target" ]] || invalid "engineering work entrypoint must not be a symlink: $target"
  if [[ -e "$target" && ! -f "$target" ]]; then
    invalid "engineering work entrypoint is not a regular file: $target"
  fi
}

ensure_safe_directory_component() {
  local target="$1"
  require_safe_directory_component "$target"
  if [[ ! -d "$target" ]]; then
    if ! mkdir -- "$target" 2>/dev/null; then
      # A competing bootstrap may have created it. Accept only the same safe
      # directory shape; never follow or replace what appeared.
      require_safe_directory_component "$target"
      [[ -d "$target" ]] || invalid "could not create engineering work directory: $target"
    fi
  fi
  require_safe_directory_component "$target"
  [[ "$(canonical_directory "$target")" == "$target" ]] ||
    invalid "engineering work directory escaped its canonical workspace path: $target"
}

is_effectively_ignored() {
  local workspace_root="$1"
  local probe="$2"
  local git_dir=""

  if git -C "$workspace_root" rev-parse --git-dir >/dev/null 2>&1; then
    git -C "$workspace_root" check-ignore --no-index -q -- "$probe"
    return
  fi

  if command -v jj >/dev/null 2>&1 &&
     git_dir="$(cd "$workspace_root" && jj --ignore-working-copy git root 2>/dev/null)" &&
     [[ -n "$git_dir" ]]; then
    git --git-dir="$git_dir" --work-tree="$workspace_root" \
      check-ignore --no-index -q -- "$probe"
    return
  fi

  return 1
}

work_id=""
work_id_source=""
work_id_argument_set=0
start_path="$PWD"
bootstrap=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --work-id)
      [[ $# -ge 2 ]] || { usage; invalid "--work-id requires a value"; }
      work_id="$2"
      work_id_source="argument"
      work_id_argument_set=1
      shift 2
      ;;
    --work-id=*)
      work_id="${1#--work-id=}"
      work_id_source="argument"
      work_id_argument_set=1
      shift
      ;;
    --path)
      [[ $# -ge 2 ]] || { usage; invalid "--path requires a value"; }
      start_path="$2"
      shift 2
      ;;
    --path=*)
      start_path="${1#--path=}"
      [[ -n "$start_path" ]] || { usage; invalid "--path requires a non-empty value"; }
      shift
      ;;
    --bootstrap)
      bootstrap=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      invalid "unknown argument: $1"
      ;;
  esac
done

if [[ $work_id_argument_set -eq 1 ]]; then
  [[ -n "$work_id" ]] || invalid "--work-id requires a non-empty value"
elif [[ -n "${ENGINEERING_WORK_ID:-}" ]]; then
  work_id="$ENGINEERING_WORK_ID"
  work_id_source="environment"
fi

if [[ -n "$work_id" ]] && ! valid_work_id "$work_id"; then
  invalid "work ID from $work_id_source must be lowercase kebab-case"
fi
[[ -d "$start_path" ]] || invalid "start path is not a directory: $start_path"

start_path="$(canonical_directory "$start_path")"
vcs=""
repo_root=""
default_workspace=""
active_workspace=""
workspace_label=""
workspace_source=""

if command -v jj >/dev/null 2>&1 &&
   active_workspace="$(cd "$start_path" && jj --ignore-working-copy root 2>/dev/null)"; then
  vcs="jj"
  active_workspace="$(canonical_directory "$active_workspace")"
  repo_root="$active_workspace"
  if default_workspace="$(cd "$start_path" &&
      jj --ignore-working-copy workspace root --name default 2>/dev/null)" &&
     [[ -d "$default_workspace" ]]; then
    default_workspace="$(canonical_directory "$default_workspace")"
  else
    default_workspace=""
  fi

  while IFS= read -r candidate_name; do
    [[ -n "$candidate_name" ]] || continue
    candidate_root="$(cd "$start_path" &&
      jj --ignore-working-copy workspace root --name "$candidate_name" 2>/dev/null || true)"
    if [[ -d "$candidate_root" ]] &&
       [[ "$(canonical_directory "$candidate_root")" == "$active_workspace" ]]; then
      workspace_label="$candidate_name"
      workspace_source="jj_workspace"
      break
    fi
  done < <(cd "$start_path" &&
    jj --ignore-working-copy workspace list -T 'name ++ "\n"' 2>/dev/null || true)
elif active_workspace="$(cd "$start_path" && git rev-parse --show-toplevel 2>/dev/null)"; then
  vcs="git"
  active_workspace="$(canonical_directory "$active_workspace")"
  repo_root="$active_workspace"
  default_workspace="$(cd "$start_path" && git worktree list --porcelain | \
    awk 'NR == 1 && $1 == "worktree" {sub(/^worktree /, ""); print; exit}')"
  if [[ -n "$default_workspace" && -d "$default_workspace" ]]; then
    default_workspace="$(canonical_directory "$default_workspace")"
  else
    default_workspace=""
  fi
  workspace_label="$(cd "$start_path" &&
    git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -n "$workspace_label" ]]; then
    workspace_source="git_branch"
  fi
else
  invalid "path is not inside a Git worktree or jj workspace: $start_path"
fi

engineering_dir="$active_workspace/.engineering"
work_root="$engineering_dir/works"
require_safe_directory_component "$engineering_dir"
require_safe_directory_component "$work_root"
if [[ -d "$engineering_dir" ]] &&
   [[ "$(canonical_directory "$engineering_dir")" != "$engineering_dir" ]]; then
  invalid "engineering directory escaped its canonical workspace path: $engineering_dir"
fi
if [[ -d "$work_root" ]] &&
   [[ "$(canonical_directory "$work_root")" != "$work_root" ]]; then
  invalid "engineering work root escaped its canonical workspace path: $work_root"
fi

work_candidates=()
candidate_dir=""
while IFS= read -r candidate_dir; do
  [[ -n "$candidate_dir" ]] || continue
  candidate_id="${candidate_dir##*/}"
  if valid_work_id "$candidate_id"; then
    work_candidates+=("$candidate_id")
  fi
done < <(find "$work_root" -mindepth 1 -maxdepth 1 \
  -type d 2>/dev/null | LC_ALL=C sort)

workspace_work_id=""
workspace_leaf_work_id=""
if [[ -n "$workspace_label" ]]; then
  helper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  workspace_work_id="$("$helper_dir/derive-engineering-name" \
    tracker-work-id "$workspace_label")"
  if [[ "$workspace_label" == */* ]]; then
    workspace_leaf_work_id="$("$helper_dir/derive-engineering-name" \
      tracker-work-id "${workspace_label##*/}")"
  fi
fi

if [[ -z "$work_id" ]]; then
  workspace_match_id=""
  meaningful_workspace_id=""
  if [[ -n "$workspace_work_id" ]] &&
     [[ ! "$workspace_work_id" =~ ^(default|main|master|trunk|item)$ ]]; then
    meaningful_workspace_id="$workspace_work_id"
  fi
  if [[ -n "$workspace_work_id" ]]; then
    for candidate_id in "${work_candidates[@]}"; do
      if [[ "$candidate_id" == "$workspace_work_id" ]]; then
        workspace_match_id="$candidate_id"
        break
      fi
    done
  fi

  if [[ -z "$workspace_match_id" && -n "$workspace_leaf_work_id" ]]; then
    for candidate_id in "${work_candidates[@]}"; do
      if [[ "$candidate_id" == "$workspace_leaf_work_id" ]]; then
        workspace_match_id="$candidate_id"
        break
      fi
    done
  fi

  if [[ -n "$workspace_match_id" ]]; then
    work_id="$workspace_match_id"
    work_id_source="$workspace_source"
  elif [[ ${#work_candidates[@]} -eq 1 && -z "$meaningful_workspace_id" ]]; then
    work_id="${work_candidates[0]}"
    work_id_source="sole_existing"
  else
    candidates_json="$(jq -n '$ARGS.positional' --args "${work_candidates[@]}")"
    jq -n \
      --arg vcs "$vcs" \
      --arg repo_root "$repo_root" \
      --arg active_workspace "$active_workspace" \
      --arg default_workspace "$default_workspace" \
      --arg workspace_label "$workspace_label" \
      --arg suggested_work_id "$workspace_work_id" \
      --argjson candidates "$candidates_json" \
      --arg error "work ID cannot be selected safely; the PM must ask the user" \
      '{status:"work_id_required", vcs:$vcs, repo_root:$repo_root,
        durable_root:$active_workspace, active_workspace:$active_workspace,
        default_workspace:(if $default_workspace == "" then null else $default_workspace end),
        workspace_label:(if $workspace_label == "" then null else $workspace_label end),
        suggested_work_id:(if ($suggested_work_id == "" or
          ($suggested_work_id | test("^(default|main|master|trunk|item)$")))
          then null else $suggested_work_id end),
        candidate_work_ids:$candidates, error:$error}'
    exit 4
  fi
fi

work_dir="$work_root/$work_id"
ignore_file="$active_workspace/.gitignore"
active_probe=".engineering/works/$work_id/state.md"

require_safe_directory_component "$work_dir"
if [[ -d "$work_dir" ]] &&
   [[ "$(canonical_directory "$work_dir")" != "$work_dir" ]]; then
  invalid "engineering work directory escaped its canonical workspace path: $work_dir"
fi
require_safe_directory_component "$work_dir/state"
require_safe_entrypoint "$work_dir/state/working.md"
require_safe_entrypoint "$work_dir/state.md"
require_safe_entrypoint "$work_dir/goal.md"
require_safe_entrypoint "$work_dir/state/journal.md"

if [[ ! -f "$ignore_file" ]] ||
   ! grep -Eq '^[[:space:]]*\.engineering/[[:space:]]*(#.*)?$' "$ignore_file" ||
   ! is_effectively_ignored "$active_workspace" "$active_probe"; then
  jq -n \
    --arg vcs "$vcs" \
    --arg repo_root "$repo_root" \
    --arg durable_root "$active_workspace" \
    --arg default_workspace "$default_workspace" \
    --arg active_workspace "$active_workspace" \
    --arg workspace_label "$workspace_label" \
    --arg work_id "$work_id" \
    --arg work_id_source "$work_id_source" \
    --arg work_dir "$work_dir" \
    --arg ignore_file "$ignore_file" \
    --arg error "PM must add .engineering/ to the active workspace .gitignore before creating work artifacts" \
    '{status:"requires_ignore", vcs:$vcs, repo_root:$repo_root,
      durable_root:$durable_root,
      default_workspace:(if $default_workspace == "" then null else $default_workspace end),
      active_workspace:$active_workspace,
      workspace_label:(if $workspace_label == "" then null else $workspace_label end),
      work_id:$work_id, work_id_source:$work_id_source, work_dir:$work_dir,
      ignore_file:$ignore_file, error:$error}'
  exit 3
fi

bootstrap_created=()
bootstrap_existing=()
write_bootstrap_file() {
  local target="$1"
  local contents="$2"

  require_safe_entrypoint "$target"
  if [[ -e "$target" ]]; then
    bootstrap_existing+=("$target")
    return
  fi

  if (set -o noclobber; printf '%s' "$contents" >"$target") 2>/dev/null; then
    bootstrap_created+=("$target")
  elif [[ -L "$target" ]]; then
    invalid "engineering work entrypoint became a symlink during bootstrap: $target"
  elif [[ -e "$target" && ! -f "$target" ]]; then
    invalid "engineering work entrypoint became non-regular during bootstrap: $target"
  elif [[ -f "$target" ]]; then
    # Another PM bootstrap won the create race. Preserve its file verbatim.
    bootstrap_existing+=("$target")
  else
    invalid "could not create bootstrap file: $target"
  fi
}

if [[ $bootstrap -eq 1 ]]; then
  ensure_safe_directory_component "$engineering_dir"
  ensure_safe_directory_component "$work_root"
  ensure_safe_directory_component "$work_dir"
  ensure_safe_directory_component "$work_dir/state"
  bootstrap_timestamp="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
  working_contents="# Current focus

- Work ID: \`$work_id\`
- Updated: \`$bootstrap_timestamp\`
- Status: \`initialized\`
- Working now: Confirm the goal, scope, and acceptance criteria.
- Handback point: First-use bootstrap is complete; discovery has not started.

## Fast paths

- Charter: [goal.md](../goal.md)
- State: [state.md](../state.md)
"
  state_contents="# Engineering work

- State role: \`root\`
- Work ID: \`$work_id\`
- Lifecycle status: \`initialized\`
- Updated: \`$bootstrap_timestamp\`
- Charter: [goal.md](goal.md)
- Current focus: [working.md](state/working.md)
- Journal: [journal.md](state/journal.md)
- Plan source: \`state.md\`
- Plan revision: \`1\`
- Next owner: \`PM\`
- Next action: Confirm the charter in goal.md with the user.
- Repository revision: Not captured yet.
- Sync state: Not started.
- Review state: Not started.

## Status

- Lifecycle: \`initialized\`
- Topology: \`linear\`
- Overall graph: \`GOL → OWN\`

## Tasks

| ID | Mark | Status | Task | Depends on | Required | Acceptance | Owner | Evidence / next action |
| --- | --- | --- | --- | --- | --- | --- | --- | --- |
| GOL | - | planned | Confirm the charter: goal, scope, and success criteria. [targets: goal.md] | — | yes | goal.md records the goal, scope, and measurable success criteria. | PM | Confirm with the user. |
| OWN | - | planned | Select the next owning skill. [targets: none] | GOL | yes | The next owning skill and handback point are recorded. | PM | Wait for GOL. |

## Decisions

None recorded.

## Dependencies, blockers, and risks

None known.

## Evidence and validation

None recorded.
"
  goal_contents="# Charter

- Work ID: \`$work_id\`
- Charter revision: \`1\`
- Created: \`$bootstrap_timestamp\`
- State: [state.md](state.md)

## Goal

Pending confirmation with the user.

## Scope and non-goals

Pending confirmation with the user.

## Success criteria

| ID | Criterion | Acceptance evidence |
| --- | --- | --- |
| SC-1 | Pending confirmation with the user. | Pending. |

## Specification provenance

Not established. For a Notion-backed contract, record the source kind, page
id, and the base-id/revision this charter was authored against. The canonical
specification remains the sole authority; a conflict with it marks this work
stream for revalidation, never the reverse.
"
  journal_contents="# Journal

Append-only event log: one line per status transition, decision, plan or
charter revision, or sync event. Newest last. Never rewrite or delete lines.

- $bootstrap_timestamp PM bootstrap: work \`$work_id\` initialized
"
  write_bootstrap_file "$work_dir/goal.md" "$goal_contents"
  write_bootstrap_file "$work_dir/state/working.md" "$working_contents"
  write_bootstrap_file "$work_dir/state.md" "$state_contents"
  write_bootstrap_file "$work_dir/state/journal.md" "$journal_contents"
  require_safe_entrypoint "$work_dir/goal.md"
  require_safe_entrypoint "$work_dir/state/working.md"
  require_safe_entrypoint "$work_dir/state.md"
  require_safe_entrypoint "$work_dir/state/journal.md"
fi

created_json="$(jq -n '$ARGS.positional' --args "${bootstrap_created[@]}")"
existing_json="$(jq -n '$ARGS.positional' --args "${bootstrap_existing[@]}")"

jq -n \
  --arg vcs "$vcs" \
  --arg repo_root "$repo_root" \
  --arg durable_root "$active_workspace" \
  --arg default_workspace "$default_workspace" \
  --arg active_workspace "$active_workspace" \
  --arg workspace_label "$workspace_label" \
  --arg work_id "$work_id" \
  --arg work_id_source "$work_id_source" \
  --arg work_dir "$work_dir" \
  --arg ignore_file "$ignore_file" \
  --argjson bootstrap_requested "$bootstrap" \
  --argjson bootstrap_created "$created_json" \
  --argjson bootstrap_existing "$existing_json" \
  '{status:"resolved", vcs:$vcs, repo_root:$repo_root,
    durable_root:$durable_root,
    default_workspace:(if $default_workspace == "" then null else $default_workspace end),
    active_workspace:$active_workspace,
    workspace_label:(if $workspace_label == "" then null else $workspace_label end),
    work_id:$work_id, work_id_source:$work_id_source, work_dir:$work_dir,
    ignore_file:$ignore_file, engineering_ignored:true,
    bootstrap_requested:($bootstrap_requested == 1),
    bootstrap_created:$bootstrap_created,
    bootstrap_existing:$bootstrap_existing}'
