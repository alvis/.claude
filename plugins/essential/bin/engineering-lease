#!/usr/bin/env bash
# Coordinator lease for one engineering work stream.
#
# The lease file <work-dir>/lease.json makes the single-writer coordinator
# role technical instead of conventional: exactly one live token may write
# coordinator-owned state files. Acquire is atomic (noclobber); heartbeat and
# release are token-gated temp-write + atomic rename; a live foreign lease is
# never replaced; an expired lease yields only to the explicit takeover verb,
# which the caller must journal as a `lease` event.
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: engineering-lease <acquire|heartbeat|release|status|takeover> \
         --work-dir <dir> [--capability <capability_id>] [--session <id>] \
         [--token <token>] [--state-revision <n>] [--ttl <seconds>]

verbs:
  acquire    create the lease when free; refuses live (contended) and expired
             (takeover_required) leases
  heartbeat  extend an owned lease (requires --token)
  release    remove an owned lease (requires --token)
  status     report free|held|expired|foreign without mutating anything
  takeover   replace an expired lease only; never a live one
EOF
}

invalid() {
  jq -n --arg message "$1" '{status:"invalid", error:$message}'
  exit 2
}

require_safe_lease_path() {
  local target="$1"
  [[ ! -L "$target" ]] || invalid "lease path must not be a symlink: $target"
  if [[ -e "$target" && ! -f "$target" ]]; then
    invalid "lease path is not a regular file: $target"
  fi
}

now_epoch() { date +%s; }
iso_utc() { date -u -r "$1" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d "@$1" +%Y-%m-%dT%H:%M:%SZ; }

new_token() {
  od -An -N16 -tx1 /dev/urandom | tr -d ' \n'
}

verb="${1:-}"
[[ -n "$verb" ]] || { usage; invalid "a verb is required"; }
case "$verb" in
  -h|--help) usage; exit 0 ;;
  acquire|heartbeat|release|status|takeover) shift ;;
  *) usage; invalid "unknown verb: $verb" ;;
esac

work_dir=""
capability=""
session=""
token=""
state_revision=""
ttl=1800
while [[ $# -gt 0 ]]; do
  case "$1" in
    --work-dir) [[ $# -ge 2 ]] || invalid "--work-dir requires a value"; work_dir="$2"; shift 2 ;;
    --work-dir=*) work_dir="${1#--work-dir=}"; shift ;;
    --capability) [[ $# -ge 2 ]] || invalid "--capability requires a value"; capability="$2"; shift 2 ;;
    --capability=*) capability="${1#--capability=}"; shift ;;
    --session) [[ $# -ge 2 ]] || invalid "--session requires a value"; session="$2"; shift 2 ;;
    --session=*) session="${1#--session=}"; shift ;;
    --token) [[ $# -ge 2 ]] || invalid "--token requires a value"; token="$2"; shift 2 ;;
    --token=*) token="${1#--token=}"; shift ;;
    --state-revision) [[ $# -ge 2 ]] || invalid "--state-revision requires a value"; state_revision="$2"; shift 2 ;;
    --state-revision=*) state_revision="${1#--state-revision=}"; shift ;;
    --ttl) [[ $# -ge 2 ]] || invalid "--ttl requires a value"; ttl="$2"; shift 2 ;;
    --ttl=*) ttl="${1#--ttl=}"; shift ;;
    -h|--help) usage; exit 0 ;;
    *) usage; invalid "unknown argument: $1" ;;
  esac
done

[[ -n "$work_dir" ]] || invalid "--work-dir is required"
[[ -d "$work_dir" ]] || invalid "work directory does not exist: $work_dir"
[[ ! -L "$work_dir" ]] || invalid "work directory must not be a symlink: $work_dir"
[[ "$ttl" =~ ^[0-9]+$ && "$ttl" -gt 0 ]] || invalid "--ttl must be a positive integer"
if [[ -n "$state_revision" ]]; then
  [[ "$state_revision" =~ ^[0-9]+$ ]] || invalid "--state-revision must be an integer"
fi

lease_path="$work_dir/lease.json"
require_safe_lease_path "$lease_path"
work_id="$(basename "$work_dir")"

read_lease() {
  jq -e . "$lease_path" 2>/dev/null
}

lease_field() {
  jq -r --arg key "$1" '.[$key] // empty' "$lease_path" 2>/dev/null
}

lease_json() {
  # args: token acquired_epoch heartbeat_epoch
  local lease_token="$1" acquired="$2" heartbeat="$3"
  local expires=$((heartbeat + ttl))
  jq -n \
    --arg work_id "$work_id" \
    --arg owner_session "$session" \
    --arg owner_capability "$capability" \
    --arg host "$(hostname 2>/dev/null || echo unknown)" \
    --argjson pid "$$" \
    --arg token "$lease_token" \
    --arg acquired_at "$(iso_utc "$acquired")" \
    --arg heartbeat_at "$(iso_utc "$heartbeat")" \
    --arg expires_at "$(iso_utc "$expires")" \
    --argjson expires_at_epoch "$expires" \
    --argjson ttl_seconds "$ttl" \
    --arg state_revision "$state_revision" \
    '{work_id: $work_id, owner_session: $owner_session,
      owner_capability: $owner_capability, host: $host, pid: $pid,
      token: $token, acquired_at: $acquired_at, heartbeat_at: $heartbeat_at,
      expires_at: $expires_at, expires_at_epoch: $expires_at_epoch,
      ttl_seconds: $ttl_seconds}
     + (if $state_revision == "" then {} else {state_revision: ($state_revision | tonumber)} end)'
}

write_lease_atomically() {
  local content="$1"
  local temp
  temp="$(mktemp "$work_dir/.lease.json.XXXXXX")"
  printf '%s\n' "$content" >"$temp"
  mv -f "$temp" "$lease_path"
}

report() {
  # args: status extra-jq-object
  local status="$1" extra="${2:-{\}}"
  jq -n --arg status "$status" --arg lease_path "$lease_path" \
    --argjson lease "$( [[ -f "$lease_path" ]] && read_lease || echo null )" \
    --argjson extra "$extra" \
    '{status: $status, lease_path: $lease_path, lease: $lease} + $extra'
}

lease_state() {
  # prints free|held|expired|foreign; "held" requires a matching --token
  if [[ ! -f "$lease_path" ]]; then
    echo free
    return
  fi
  read_lease >/dev/null || { echo corrupt; return; }
  local expires_epoch current_token
  expires_epoch="$(lease_field expires_at_epoch)"
  current_token="$(lease_field token)"
  if [[ -z "$expires_epoch" || "$(now_epoch)" -ge "$expires_epoch" ]]; then
    echo expired
  elif [[ -n "$token" && "$token" == "$current_token" ]]; then
    echo held
  else
    echo foreign
  fi
}

state="$(lease_state)"

case "$verb" in
  status)
    report "$state"
    ;;

  acquire)
    [[ -n "$capability" ]] || invalid "acquire requires --capability"
    [[ -n "$session" ]] || invalid "acquire requires --session"
    case "$state" in
      free) ;;
      corrupt) report corrupt; exit 4 ;;
      expired) report takeover_required; exit 4 ;;
      *) report contended; exit 3 ;;
    esac
    fresh_token="$(new_token)"
    now="$(now_epoch)"
    content="$(lease_json "$fresh_token" "$now" "$now")"
    if ( set -o noclobber; printf '%s\n' "$content" >"$lease_path" ) 2>/dev/null; then
      report acquired "$(jq -n --arg token "$fresh_token" '{token: $token}')"
    else
      # A competing acquire won the noclobber race; report the winner.
      require_safe_lease_path "$lease_path"
      report contended
      exit 3
    fi
    ;;

  heartbeat)
    [[ -n "$token" ]] || invalid "heartbeat requires --token"
    case "$state" in
      held) ;;
      free) report free; exit 4 ;;
      expired) report expired; exit 4 ;;
      *) report refused; exit 5 ;;
    esac
    now="$(now_epoch)"
    acquired_epoch="$(date -u -d "$(lease_field acquired_at)" +%s 2>/dev/null || now_epoch)"
    # Preserve original ownership fields; refresh heartbeat and expiry.
    capability="${capability:-$(lease_field owner_capability)}"
    session="${session:-$(lease_field owner_session)}"
    state_revision="${state_revision:-$(lease_field state_revision)}"
    write_lease_atomically "$(lease_json "$token" "$acquired_epoch" "$now")"
    report renewed
    ;;

  release)
    [[ -n "$token" ]] || invalid "release requires --token"
    case "$state" in
      held) ;;
      free) report free; exit 0 ;;
      expired)
        # Only the owner may clean up its own expired lease.
        [[ "$token" == "$(lease_field token)" ]] || { report refused; exit 5; }
        ;;
      *) report refused; exit 5 ;;
    esac
    rm -f -- "$lease_path"
    report released
    ;;

  takeover)
    [[ -n "$capability" ]] || invalid "takeover requires --capability"
    [[ -n "$session" ]] || invalid "takeover requires --session"
    case "$state" in
      expired|corrupt) ;;
      free) report free; exit 4 ;;
      *) report refused; exit 5 ;;
    esac
    previous="$( [[ -f "$lease_path" ]] && read_lease || echo null )"
    # Serialize competing takeovers with a noclobber guard; a guard older
    # than 60s is a crashed takeover and may be cleared.
    guard="$work_dir/.lease.takeover"
    if ! ( set -o noclobber; printf '%s\n' "$$" >"$guard" ) 2>/dev/null; then
      guard_age=$(( $(now_epoch) - $(stat -c %Y "$guard" 2>/dev/null || stat -f %m "$guard") ))
      if [[ "$guard_age" -lt 60 ]]; then
        report contended
        exit 3
      fi
      rm -f -- "$guard"
      ( set -o noclobber; printf '%s\n' "$$" >"$guard" ) 2>/dev/null || { report contended; exit 3; }
    fi
    fresh_token="$(new_token)"
    now="$(now_epoch)"
    write_lease_atomically "$(lease_json "$fresh_token" "$now" "$now")"
    rm -f -- "$guard"
    report taken_over "$(jq -n --arg token "$fresh_token" --argjson previous "$previous" \
      '{token: $token, previous_lease: $previous, journal_event: "lease"}')"
    ;;
esac
