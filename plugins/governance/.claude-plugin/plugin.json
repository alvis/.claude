{
  "name": "governance",
  "description": "Tools for creating and managing Claude Code configuration files including commands, skills, standards, and agents",
  "version": "2026-07-10",
  "author": {"name": "Alvis HT Tang", "email": "alvis@hilbert.space"},
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"}]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/shared/scripts/user-prompt-submit.sh ${CLAUDE_PLUGIN_ROOT}"}]
      }
    ]
  }
}
