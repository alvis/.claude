{
  "name": "governance",
  "dependencies": ["essential"],
  "description": "Tools for creating and managing Claude Code configuration files including commands, skills, standards, and agents",
  "version": "2026-07-13a",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/../essential/bin/session-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--with-session-id", "--constitution-paths", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ]
  }
}
