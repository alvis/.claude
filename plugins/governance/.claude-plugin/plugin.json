{
  "name": "governance",
  "dependencies": ["essential"],
  "description": "Tools for creating and managing Claude Code configuration files including commands, skills, standards, and agents",
  "version": "2026-07-13b",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "b=\"$(ls -d \"${CLAUDE_PLUGIN_ROOT}\"/../../essential/*/bin 2>/dev/null | sort | tail -n1)\"; [ -n \"$b\" ] || exit 0; exec \"$b/session-start\" --plugin-dir \"${CLAUDE_PLUGIN_ROOT}\" --with-session-id --constitution-paths \"${CLAUDE_PLUGIN_ROOT}\""}]
      }
    ]
  }
}
