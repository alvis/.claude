{
  "name": "agent",
  "description": "Specialist subagent team + delegation guidance. /install-agents materializes the 20-agent roster into ~/.claude/agents; the team-first mandate (CLAUDE.md) is injected each session and subagent conduct (SUBAGENT.md) at each subagent start.",
  "version": "2026-07-13a",
  "dependencies": ["essential", "coding", "web", "react", "backend"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/../essential/bin/session-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--with-session-id", "--constitution-paths", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/../essential/bin/subagent-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--constitution-paths", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ]
  }
}
