{
  "name": "theriety",
  "dependencies": ["coding", "specification", "essential"],
  "description": "Domain-specific service and data orchestrator lifecycle management for Theriety — build and audit services and data layers",
  "version": "2026-07-13a",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "b=\"$(ls -d \"${CLAUDE_PLUGIN_ROOT}\"/../../essential/*/bin 2>/dev/null | sort | tail -n1)\"; [ -n \"$b\" ] || exit 0; exec \"$b/session-start\" --plugin-dir \"${CLAUDE_PLUGIN_ROOT}\" --with-session-id --constitution-paths \"${CLAUDE_PLUGIN_ROOT}\""}]
      }
    ]
  }
}
