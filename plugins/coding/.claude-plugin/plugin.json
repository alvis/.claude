{
  "name": "coding",
  "dependencies": ["essential"],
  "description": "General code writing tools including quality checks, testing, architecture, and implementation support",
  "version": "2026-07-10",
  "mcpServers": "./mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/../essential/bin/session-start", "args": ["--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--constitution-paths", "${CLAUDE_PLUGIN_ROOT}/.claude", "${CLAUDE_PLUGIN_ROOT}"]}]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/lean-code/instructions.md\"",
            "timeout": 5,
            "statusMessage": "Loading lean-code mode..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lean-code/subagent-start.sh",
            "timeout": 5,
            "statusMessage": "Loading lean-code mode..."
          }
        ]
      }
    ]
  }
}
