{
  "name": "coding",
  "dependencies": ["essential"],
  "description": "General code writing tools including quality checks, testing, architecture, and implementation support",
  "version": "2026-07-13b",
  "mcpServers": "./mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "b=\"$(ls -d \"${CLAUDE_PLUGIN_ROOT}\"/../../essential/*/bin 2>/dev/null | sort | tail -n1)\"; [ -n \"$b\" ] || exit 0; exec \"$b/session-start\" --plugin-dir \"${CLAUDE_PLUGIN_ROOT}\" --constitution-paths \"${CLAUDE_PLUGIN_ROOT}/.claude\" \"${CLAUDE_PLUGIN_ROOT}\""}]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [{"type": "command", "command": "b=\"$(ls -d \"${CLAUDE_PLUGIN_ROOT}\"/../../essential/*/bin 2>/dev/null | sort | tail -n1)\"; [ -n \"$b\" ] || exit 0; exec \"$b/subagent-start\" --plugin-dir \"${CLAUDE_PLUGIN_ROOT}\" --constitution-paths \"${CLAUDE_PLUGIN_ROOT}/.claude\" \"${CLAUDE_PLUGIN_ROOT}\""}]
      }
    ]
  }
}
