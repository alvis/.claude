{
  "name": "coding",
  "dependencies": ["essential"],
  "description": "General code writing tools including quality checks, testing, architecture, and implementation support",
  "version": "2026-07-10",
  "author": {"name": "Alvis HT Tang", "email": "alvis@hilbert.space"},
  "mcpServers": "./mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "bash", "args": ["-c", "essential_root=\"$(claude plugin list --json | jq -r '[.[] | select(.id == \"essential@alvis\" and .enabled)][0].installPath // empty')\"; test -n \"$essential_root\"; exec \"$essential_root/bin/alvis-session-start\" \"$@\"", "alvis-session-start", "--plugin-dir", "${CLAUDE_PLUGIN_ROOT}", "--constitution-paths", "${CLAUDE_PLUGIN_ROOT}/.claude", "${CLAUDE_PLUGIN_ROOT}"]}]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat \"${CLAUDE_PLUGIN_ROOT}/hooks/lean-code/instructions.md\"",
            "timeout": 5,
            "statusMessage": "Loading lean-code mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "bash", "args": ["-c", "essential_root=\"$(claude plugin list --json | jq -r '[.[] | select(.id == \"essential@alvis\" and .enabled)][0].installPath // empty')\"; test -n \"$essential_root\"; exec \"$essential_root/bin/alvis-user-prompt-submit\" \"$@\"", "alvis-user-prompt-submit", "${CLAUDE_PLUGIN_ROOT}"]}]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lean-code/subagent-start.sh",
            "timeout": 5,
            "statusMessage": "Loading lean-code mode..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop.sh"}]
      }
    ]
  }
}
