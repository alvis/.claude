flowchart TD
    subgraph foundation[Foundation]
        PackageA[<PackageA>]
        PackageB[<PackageB>]
    end

    subgraph runtime[Runtime]
        PackageC[<PackageC>]
        PackageD[<PackageD>]
    end

    subgraph extension[Extension]
        PackageE[<PackageE>]
        PackageF[<PackageF>]
    end

    subgraph integrations[Integrations]
        PackageG[<PackageG>]
        PackageH[<PackageH>]
    end

    PackageC --> PackageA
    PackageC --> PackageB
    PackageD --> PackageA
    PackageE --> PackageC
    PackageF --> PackageC
    PackageF --> PackageD
    PackageG --> PackageE
    PackageH --> PackageE
    PackageH --> PackageF

