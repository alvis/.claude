{
  "eligibility": {
    "extensions": [".tsx", ".jsx"],
    "conditional_kinds": ["stories", "spec", "test"]
  },
  "exclusions": [
    "**/*.d.tsx",
    "**/*.generated.tsx",
    "**/__snapshots__/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**"
  ],
  "standards": [
    "../../constitution/standards/accessibility",
    "../../constitution/standards/components",
    "../../constitution/standards/hooks",
    "../../constitution/standards/project-structure",
    "../../constitution/standards/storybook"
  ],
  "scanners": [
    {
      "path": "../../scripts/scan_potential_violations.py",
      "needs_coding_scanlib": true
    }
  ],
  "report_label": "React lint"
}
